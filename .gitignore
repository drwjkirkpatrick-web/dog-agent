# ──────────────────────────────────────────────────────────────────────────────
# Dog Agent — .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ─── Python bytecode ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ─── Virtual environment ─────────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ─── IDE / Editor ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Distribution / Build ────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/

# ─── Config (contains secrets) ───────────────────────────────────────────────
config.yaml

# ─── Data (generated at runtime) ─────────────────────────────────────────────
data/
!data/.gitkeep

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
cron_logs/
*.log

# ─── Python pytest / coverage ────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage/
htmlcov/
*.coverage

# ─── mypy / type checking ───────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ─── Jupyter Notebooks (if any) ─────────────────────────────────────────────
.ipynb_checkpoints/

# ─── OS / Environment ───────────────────────────────────────────────────────
.env.local
.env.*